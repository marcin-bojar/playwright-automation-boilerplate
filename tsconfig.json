{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@Tests/*": [
                "tests/*"
            ]
        },
        "types": [
            "node"
        ]
    },
    "include": [
        "playwright.config.ts",
        "tests/**/*.ts"
    ]
}
