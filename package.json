{
    "name": "test-automation-boilerplate",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "e2e:debug": "playwright test --debug",
        "e2e:cleanup": "playwright test --project=cleanup --output=null",
        "install:browsers": "playwright install",
        "typescript": "tsc --noEmit"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@types/node": "^24.10.2",
        "typescript": "^5.8.2"
    }
}
